XUI_DEBUG=true
XUI_DB_FOLDER=x-ui
XUI_LOG_FOLDER=x-ui
XUI_BIN_FOLDER=x-ui

# Default mode is sqlite. Leave XUI_DB_DRIVER=sqlite to keep current behavior.
XUI_DB_DRIVER=sqlite

# Enable Postgres by switching the driver and filling the DSN below.
# Because the main panel uses host networking in docker-compose, the app should
# connect to Postgres through localhost and the published port.
# Example:
# XUI_DB_DRIVER=postgres
# XUI_POSTGRES_DSN=host=127.0.0.1 port=5432 user=xui password=change_me dbname=xui sslmode=disable TimeZone=UTC
XUI_POSTGRES_DSN=

XUI_DB_MAX_IDLE_CONNS=10
XUI_DB_MAX_OPEN_CONNS=50

POSTGRES_DB=xui
POSTGRES_USER=xui
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
